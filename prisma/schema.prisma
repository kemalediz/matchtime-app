generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  UPCOMING
  TEAMS_GENERATED
  TEAMS_PUBLISHED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  CONFIRMED
  BENCH
  DROPPED
}

enum Team {
  RED
  YELLOW
}

enum MemberRole {
  OWNER
  ADMIN
  PLAYER
}

// ─── NextAuth Adapter Tables ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Domain ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phoneNumber   String?   @unique
  seedRating    Float?
  matchRating   Int       @default(1000) // Elo-style; updated after each completed match with a score
  isSuperadmin  Boolean   @default(false) // platform-level operator; see all orgs
  isActive      Boolean   @default(true)
  onboarded     Boolean   @default(false)

  accounts          Account[]
  sessions          Session[]
  memberships       Membership[]
  attendances       Attendance[]
  ratingsGiven      Rating[]         @relation("RatingsGiven")
  ratingsReceived   Rating[]         @relation("RatingsReceived")
  momVotesGiven     MoMVote[]        @relation("MoMVotesGiven")
  momVotesReceived  MoMVote[]        @relation("MoMVotesReceived")
  teamAssignments   TeamAssignment[]
  activityPositions PlayerActivityPosition[]
  ratingAdjustments RatingAdjustment[]
  aliases           UserAlias[]
  rosterSurveyDMs   RosterSurveyDM[]
  rosterSurveyResponses RosterSurveyResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organisation {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  logo               String?
  inviteCode         String   @unique @default(cuid())
  whatsappGroupId    String?
  whatsappBotEnabled Boolean  @default(false)

  /// The player who collects match fees on behalf of the group.
  /// Often a trusted long-serving member, not always the OWNER
  /// (e.g. Sutton FC — Kemal owns the org, Elvin collects payments).
  /// When non-null, this user is excluded from the "who hasn't paid"
  /// chase because they're the one being paid. Derived at onboarding
  /// by the LLM from chat patterns ("send me £7", "paid you back")
  /// and overridable in admin settings. Nullable — falls back to no
  /// exclusion if we can't determine.
  paymentHolderId String?

  /// Per-org flag: should the bot track who has paid and chase
  /// outstanding payments? When `true`, the daily 17:00 update
  /// includes the "💳 N payments still pending" tail, the LLM
  /// processes "X paid for N players" admin messages into
  /// PaymentCredit rows / Attendance.paidAt updates, and ticking
  /// the WA payment poll writes paidAt on the voter's Attendance.
  /// When `false`, the payment poll still posts at match-end (it's
  /// gated separately by Match.postMatchEndFlow) — but every other
  /// payment-tracking side-effect goes silent. Default OFF: orgs
  /// opt in to tracking. Sutton FC opted out 2026-04-29 because
  /// Elvin (the money taker) finds the chase overhead unnecessary
  /// and prefers tracking offline.
  paymentTrackingEnabled Boolean @default(false)

  /// Org-level override for the two team DISPLAY labels (lineups,
  /// score prompts, payment poll, match pages…). Index 0 maps to the
  /// canonical Team enum RED, index 1 to YELLOW — the enum itself
  /// never changes, only what we call the teams. Empty (default) or
  /// an empty-string slot falls back to the Sport's `teamLabels`,
  /// then to ["Red","Yellow"]. Resolved everywhere via
  /// `resolveTeamLabels()` in src/lib/team-labels.ts; editable by an
  /// org admin on /admin/settings.
  teamLabels String[] @default([])

  /// ─── Per-feature module flags ───────────────────────────────────
  /// Each toggles one bot capability independently so a group can run
  /// only the bits it wants (Amir's Thursday group: MoM + rating
  /// only). Gated at every side-effect entry point via
  /// `getOrgFeatures()` in src/lib/org-features.ts.
  ///
  /// Default TRUE for the established behaviours so existing orgs
  /// (Sutton FC — live production) keep working unchanged on
  /// migration; new orgs get these set explicitly by the onboarding
  /// flow. Payment is the pre-existing `paymentTrackingEnabled`
  /// (default OFF, opt-in) — left as-is so its current gates and
  /// Sutton's opted-out state don't change.
  featureAttendance    Boolean @default(true)  // IN/OUT tracking, squad list, chase, short-squad replies
  featureBench         Boolean @default(true)  // bench prompts, fill-on-drop, bench-confirmation
  featureTeamBalancing Boolean @default(true)  // generate_teams_request + the balancer
  featureMomVoting     Boolean @default(true)  // MoM poll + 5-day announcement
  featurePlayerRating  Boolean @default(true)  // post-match rating links/DMs
  featureReminders     Boolean @default(true)  // @MatchTime personal reminder_request
  featureStatsQa       Boolean @default(true)  // Recent-History stats answers

  /// "Squad from pasted list" mode (Amir's Thursday group shape, 2026-05-20).
  /// Some groups don't say IN/OUT — instead, every player copies the latest
  /// numbered squad message, appends their own line, and re-pastes the whole
  /// list. The bot derives the squad from the LATEST such list before kickoff
  /// (one LLM call per match over messages SINCE THE PREVIOUS MATCH ENDED;
  /// no per-batch analyzer). See `computeSinceForOrg` in squad-from-list.ts
  /// for the bootstrap + MAX_WINDOW_DAYS cap rules.
  ///
  /// Crucially, the bot also DIFFS each consecutive list against the previous
  /// one: the names added are attributed to that message's SENDER. When the
  /// sender's pushname matches one of the additions, that becomes a
  /// ground-truth UserAlias (e.g. ~T → "Tharan") — solving the nickname
  /// matching problem that letter-overlap fuzzy can never bridge.
  /// Other additions are signed-in guests (admin can fill in their phone
  /// later at /admin/players, same flow Sutton uses for any phone-less player).
  ///
  /// Default OFF (additive, no impact on Sutton). Auto-set TRUE at the end of
  /// onboarding for orgs that pick MoM and/or ratings but NOT attendance —
  /// i.e. groups that need a squad-of-record post-match (for MoM poll + rating
  /// DMs) but don't use the bot for in/out chatter.
  featureSquadFromList Boolean @default(false)

  /// ─── Stripe payments (2026-06-03) ───────────────────────────────
  /// Per-match fee collection. The money collector is `paymentHolderId`
  /// (surfaced as "Money collector" in org setup). The three methods
  /// below are independently toggleable; at least one must stay on when
  /// `paymentCollectionEnabled`. Surcharge-safe pricing: card is the
  /// standard (highest) price, pay-by-bank a discount, direct = base.
  /// Nothing here charges anyone until Stripe is connected AND
  /// paymentCollectionEnabled is true — fully gated, additive.
  paymentCollectionEnabled Boolean @default(false)
  /// Pay by Bank (open banking) — cheapest rail, the recommended default.
  payMethodPayByBank       Boolean @default(true)
  /// Card / Apple Pay / Google Pay — fallback rail.
  payMethodCard            Boolean @default(true)
  /// "Pay the collector directly" (cash/transfer) — honesty path, the
  /// collector confirms receipt. No processor fee.
  payMethodDirect          Boolean @default(true)
  /// The money collector's connected Stripe (Express) account id. Set
  /// when they complete the one-time bank onboarding. Null = not yet
  /// connected → Stripe rails unavailable, only "direct" can run.
  stripeConnectAccountId   String?
  /// True once Stripe reports the connected account can accept charges
  /// + receive payouts (onboarding fully complete).
  stripeChargesEnabled     Boolean @default(false)

  memberships    Membership[]
  activities     Activity[]
  sports         Sport[]
  userAliases    UserAlias[]
  rosterSurveys  RosterSurvey[]
  groupMessages  GroupMessage[]
  windowVerdicts WindowVerdict[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * Phase 2 — autonomous in-group onboarding. When a moderator types
 * "@MatchTime setup" in a group with no org, the bot runs a
 * conversational setup IN THE GROUP (anyone can answer): gather the
 * event details, then the feature menu, then create
 * Sport/Activity/Match + flip the Phase-1 feature flags.
 *
 * One active row per WhatsApp group. `stage` drives the LLM's next
 * question; collected answers accumulate as we go. orgId is filled in
 * once we provision the Organisation (at "features" stage, so the
 * group becomes monitored normally). `selectedFeatures` holds the
 * FeatureKey strings the group chose.
 */
model OnboardingSession {
  id              String   @id @default(cuid())
  whatsappGroupId String
  /// Filled once the Organisation is provisioned (features stage).
  orgId           String?
  /// "collecting" → asking event questions
  /// "features"   → org created, asking which features to enable
  /// "completed"  → Activity/Match created, flags set, normal ops
  /// "abandoned"  → admin/cron cleaned up a stale session
  stage           String   @default("collecting")

  // Collected event details (nullable until answered).
  groupName       String?
  venue           String?
  dayOfWeek       Int?     // 0=Sun..6=Sat
  kickoffTime     String?  // "21:30" (London wall clock)
  playersPerSide  Int?     // 7 → 7-a-side
  recurrence      String?  // "weekly" | "oneoff"
  oneOffDate      String?  // ISO date when recurrence = oneoff

  selectedFeatures String[]

  /// Last waMessageId we replied to — dedupe so a re-flushed batch
  /// doesn't re-ask the same question.
  lastHandledWaId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([whatsappGroupId, stage])
}

model Sport {
  id                  String   @id @default(cuid())
  orgId               String
  org                 Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name                String               // "Football 7-a-side"
  preset              String?              // "football-7aside" | "basketball-5v5" | null for custom
  playersPerTeam      Int
  positions           String[]             // ["GK","DEF","MID","FWD"]
  teamLabels          String[]             // ["Red","Yellow"]
  mvpLabel            String   @default("Man of the Match")
  balancingStrategy   String   @default("position-aware") // "position-aware" | "rating-only"
  positionComposition Json?                // { GK: 1, DEF: 2, MID: 2, FWD: 2 } — per-team target

  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model Membership {
  id     String     @id @default(cuid())
  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId  String
  org    Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role   MemberRole @default(PLAYER)

  /// Non-null when the user has been detected as leaving the org's
  /// WhatsApp group (bot `group_leave` event) or been manually removed
  /// by an admin. We keep the membership row for history (so past
  /// attendances/ratings stay attributable) — just exclude "left" rows
  /// from roster queries. A `group_join` later will null this back out.
  leftAt DateTime?

  /// Non-null when this membership was auto-created by the analyzer
  /// because an unknown sender posted in the org's monitored group.
  /// The admin dashboard surfaces these so owners can fill in phone,
  /// position, seed rating, or remove them if they're not a player.
  /// Cleared once an admin edits the player (confirming they're real).
  provisionallyAddedAt DateTime?

  /// Last time the bot saw this user in the org's WhatsApp group
  /// participant list (via /api/whatsapp/sync-participants on bot
  /// startup). Used to scope DM-blast features (roster check-in
  /// survey) to only members currently in the group, per Kemal's
  /// "don't message people who already left" rule. Null = never seen
  /// in a sync (could be pre-sync legacy member, or genuinely gone).
  lastSeenInGroupAt DateTime?

  /// Per-club opt-out for rating + Man-of-the-Match DMs. When true the
  /// post-match rating DM and the daily rating-reminder DM are both
  /// suppressed for this member in this org. Deliberately narrow: it
  /// does NOT suppress match invites/recruit DMs, payment chases, or
  /// answers to questions the player initiates. Set via the DM
  /// keyword fast-path in /api/whatsapp/dm-reply ("stop messaging me
  /// about ratings"). Re-opt-in clears both columns.
  ratingDmOptOut   Boolean   @default(false)
  ratingDmOptOutAt DateTime?

  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([leftAt])
}

model Activity {
  id                String       @id @default(cuid())
  orgId             String
  org               Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sportId           String
  sport             Sport        @relation(fields: [sportId], references: [id])
  name              String
  dayOfWeek         Int          // 0=Sun..6=Sat
  time              String       // "21:30"
  venue             String
  isActive          Boolean      @default(true)
  deadlineHours     Int          @default(5)
  matchDurationMins Int          @default(60)
  ratingWindowHours Int          @default(120) // 5 days — aligns with MoM announcement & magic-link TTL

  /// Default per-player match fee (£) for this activity/format. The
  /// 5-a-side and 7-a-side activities each carry their own, so a format
  /// switch auto-applies the right fee. Null = no default; the collector
  /// is asked each week. This is the BASE fee (before the per-method
  /// processing uplift). 2026-06-03.
  feePerPlayer      Float?
  /// When true, the collector enters the TOTAL pitch cost and MatchTime
  /// divides by who played, instead of a fixed per-player fee.
  feeSplitTotal     Boolean      @default(false)

  matches           Match[]
  playerPositions   PlayerActivityPosition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([sportId])
}

model PlayerActivityPosition {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  positions  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, activityId])
  @@index([activityId])
}

model Match {
  id                 String      @id @default(cuid())
  activityId         String
  activity           Activity    @relation(fields: [activityId], references: [id])
  date               DateTime
  maxPlayers         Int
  status             MatchStatus @default(UPCOMING)
  attendanceDeadline DateTime
  redScore           Int?
  yellowScore        Int?
  /// When false, the bot skips match-end postings (payment poll, rating-link DMs,
  /// MoM announcement, rating-reminder DMs) for this specific match. Useful for
  /// the first match after launch while the rating UI is still maturing.
  postMatchEndFlow   Boolean     @default(true)

  /// Synthetic historical match — NOT a real scheduled match, just an
  /// anchor for pre-MatchTime MoM votes we backfilled from WhatsApp
  /// chat history. Dashboards, the bot scheduler, and "recent results"
  /// lists all exclude these so they don't pollute present-day UX.
  /// The leaderboard's MoM-count query DOES include them — which is
  /// the whole point of backfilling.
  isHistorical       Boolean     @default(false)

  /// ─── Per-match fee capture (2026-06-03) ─────────────────────────
  /// The agreed per-player fee for THIS match (£, base before method
  /// uplift). Set when the money collector tells MatchTime the amount
  /// (chat capture) or from the activity default. Null = not set yet.
  feePerPlayer           Float?
  /// Amount the collector proposed but hasn't confirmed yet — MatchTime
  /// echoes it back and waits for ✅ before releasing links.
  feePendingConfirm      Float?
  /// Who set the fee + when (audit).
  feeSetByUserId         String?
  feeSetAt               DateTime?
  /// Set when the per-player payment-link DMs have gone out. Null = not
  /// released yet (fee not confirmed). Gates the chaser.
  paymentLinksReleasedAt DateTime?

  attendances            Attendance[]
  teamAssignments        TeamAssignment[]
  ratings                Rating[]
  momVotes               MoMVote[]
  sentNotifications      SentNotification[]
  benchConfirmations     PendingBenchConfirmation[]
  benchSlotOffers        BenchSlotOffer[]
  ratingAdjustments      RatingAdjustment[]
  paymentCredits         PaymentCredit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
}

/**
 * Every WhatsApp-bot message the scheduler asks the bot to send is logged
 * here with a stable key so it doesn't fire twice. Keys look like
 * "<matchId>:<kind>" (group-wide events) or "<matchId>:<kind>:<userId>"
 * (per-user DMs / reminders).
 */
model SentNotification {
  id         String   @id @default(cuid())
  key        String   @unique
  kind       String                    // e.g. "announce-match", "daily-in-list", "match-teams", ...
  matchId    String?
  match      Match?   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  targetUser String?                   // userId when it's a per-user DM
  waMessageId String?                  // WhatsApp message id for reaction tracking
  createdAt  DateTime @default(now())

  @@index([matchId])
  @@index([kind])
}

/**
 * Ad-hoc queue for bot work the scheduler should dispatch on its next
 * tick. Used for one-off admin actions (e.g. "send a test DM to Kemal")
 * that don't map onto the regular match-lifecycle triggers. Scheduler
 * picks up rows with `sentAt == null`, emits matching instructions, and
 * marks `sentAt` on ACK so they don't repeat.
 */
/**
 * Short-lived one-time passcodes used by the phone-number signup flow.
 * Owner delivers codes via WhatsApp DM (using the shared MatchTime
 * bot) and verifies them at /signup/verify.
 *
 * Rate-limiting: we keep rows around past usedAt/expiresAt briefly to
 * throttle resends — a separate sweep drops them after 24h.
 */
model PhoneOtp {
  id        String   @id @default(cuid())
  /// Normalised phone number (no "+" prefix; purely digits).
  phone     String
  code      String   // 6 digits, zero-padded
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}

/**
 * Roster check-in survey. An admin triggers one when attendance has
 * been thin and they want to know who's still committed. The bot
 * DMs every active member; replies are LLM-classified into
 * in/maybe/out/unclear; admins read raw replies + override on the
 * dashboard.
 *
 * Lifecycle: status="open" while DMs are out and replies trickle in.
 * Once admin closes it (or after a manual cleanup pass), status="closed"
 * — daily group updates stop, no more replies are accepted.
 */
model RosterSurvey {
  id           String  @id @default(cuid())
  orgId        String
  org          Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sentByUserId String                                               // admin who triggered
  status       String  @default("open")                             // "open" | "closed"
  closedAt     DateTime?
  closedById   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dms       RosterSurveyDM[]
  responses RosterSurveyResponse[]

  @@index([orgId, status])
}

/// One row per surveyed member — tracks the outbound DM. `sentAt`
/// fills in when the bot ACKs delivery; `failedReason` populated if
/// WhatsApp rejected the DM (e.g. number blocked the bot or doesn't
/// have an account). Admin dashboard uses this to show "pending"
/// (no Response yet) vs "delivery failed".
model RosterSurveyDM {
  id           String  @id @default(cuid())
  surveyId     String
  survey       RosterSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId       String
  user         User    @relation(fields: [userId], references: [id])
  botJobId     String?
  sentAt       DateTime?
  failedReason String?
  createdAt    DateTime @default(now())

  @@unique([surveyId, userId])
  @@index([surveyId])
}

/// One row per (survey, user) — latest reply wins (upsert on each
/// new DM from the same user). `rawReply` is the verbatim text the
/// user sent so the admin can read it on the dashboard. `response`
/// is the LLM's classification; `adminOverride=true` means an admin
/// changed it manually and the LLM shouldn't re-flip it.
model RosterSurveyResponse {
  id            String   @id @default(cuid())
  surveyId      String
  survey        RosterSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  response      String                                              // "in" | "maybe" | "out" | "unclear"
  rawReply      String   @db.Text
  classifiedAt  DateTime @default(now())
  adminOverride Boolean  @default(false)

  @@unique([surveyId, userId])
  @@index([surveyId])
}

model BotJob {
  id       String   @id @default(cuid())
  orgId    String
  kind     String                   // "dm" | "group" | "group-poll"
  phone    String?                  // for DM jobs, E.164 without the + prefix
  text     String   @db.Text
  /// Poll fields — set when kind = "group-poll". `text` should mirror
  /// the question for admin-dashboard previews. If pollQuestion is
  /// non-null, pollOptions must contain at least 2 entries.
  pollQuestion String?  @db.Text
  pollOptions  String[]
  pollMulti    Boolean  @default(false)
  /// When set, this job must NOT be dispatched until the clock passes
  /// this instant. Used for player-requested personal reminders
  /// ("@MatchTime remind me on Monday") — the analyzer resolves the
  /// natural-language time to an absolute UTC timestamp and queues a
  /// kind="dm" job with sendAfter in the future. The scheduler's
  /// BotJob block filters `sendAfter == null OR sendAfter <= now()`, so
  /// existing immediate jobs (sendAfter null) are unaffected. Nullable
  /// = additive, zero impact on historical/immediate jobs.
  sendAfter    DateTime?
  sentAt   DateTime?
  createdAt DateTime @default(now())

  @@index([orgId, sentAt])
  @@index([orgId, sendAfter])
}

/**
 * Queued retroactive react updates.
 *
 * When a player's slot changes after their original IN message has
 * already been reacted to (drop-and-shift, slot-emoji rule changes,
 * historical fixes), the server queues a row here. The bot's next
 * /due-posts tick picks up unsent rows, calls `msg.react(emoji)` on the
 * existing WhatsApp message, and ACKs back to mark `sentAt`.
 *
 * Reaction replacement is in-place — whatsapp-web.js's react() swaps
 * any existing reaction the bot account placed on that message, so we
 * don't need a separate "clear" step.
 */
model RetroReaction {
  id          String    @id @default(cuid())
  orgId       String
  waMessageId String
  emoji       String
  reason      String?                // optional debug note: "slot 5 → 4 after drop"
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([orgId, sentAt])
  @@index([waMessageId])
}

/**
 * When someone drops from a confirmed slot, the bot DMs the first bench
 * player and asks them to 👍 (confirm) or 👎 (pass) within 2h. One row
 * per (match, user) attempt. Resolved when a reaction arrives OR when
 * `expiresAt` passes — at which point the server flags this user as
 * dropped and the scheduler posts a new prompt for the next bencher.
 */
model PendingBenchConfirmation {
  id          String    @id @default(cuid())
  matchId     String
  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String
  waMessageId String?                // the bot's prompt message id; filled in by /ack
  expiresAt   DateTime
  resolvedAt  DateTime?
  outcome     String?                // "confirmed" | "declined" | "expired"
  /// The CONFIRMED player whose drop opened this slot. When this bench
  /// user 👍s, their TeamAssignment takes the dropped player's slot
  /// (the dropped TA row is deleted). On 👎/timeout, the chain to the
  /// next bench player preserves this reference so they're offered
  /// the same slot. Nullable: legacy rows + edge cases (drop happened
  /// before teams were generated) fall back to the old behaviour
  /// (attendance-only confirmation, no team swap, no announcement).
  replacingUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([resolvedAt])
}

/**
 * Bench redesign 2026-05-19 (Kemal). Replaces the sequential
 * elimination chain (PendingBenchConfirmation, now legacy/unused —
 * kept for history, not written anymore).
 *
 * ONE row per OPEN SLOT. A confirmed player dropping opens an offer
 * that is broadcast to EVERY current bench player at once. The FIRST
 * bencher to confirm (👍 / IN / yes — in the group OR by DM) claims
 * it: they're promoted to CONFIRMED, the dropped player's
 * TeamAssignment transfers to them, the group is told, and the offer
 * is resolved. Everyone else stays on the bench — nobody is ever
 * removed for being slow or silent. No per-person timers. Offers
 * auto-close at kickoff.
 *
 * `replacingUserId` = the dropped CONFIRMED player (for the TA swap +
 * "X takes Y's place" wording). `waMessageId` = the group offer post
 * (set on /ack) so a 👍 reaction maps back to the offer.
 * `claimedByUserId` = who won it (audit). `resolvedAt` set when
 * claimed or auto-closed at kickoff.
 */
model BenchSlotOffer {
  id              String    @id @default(cuid())
  matchId         String
  match           Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  replacingUserId String?
  waMessageId     String?
  claimedByUserId String?
  resolvedAt      DateTime?
  outcome         String?   // "claimed" | "closed-at-kickoff"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([matchId, resolvedAt])
}

model Attendance {
  id          String           @id @default(cuid())
  matchId     String
  match       Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  status      AttendanceStatus @default(CONFIRMED)
  position    Int              @default(0)
  respondedAt DateTime         @default(now())
  /// Non-null when the player has marked themselves as paid for this
  /// match. Populated by the bot when the voter ticks their team's
  /// option in the WhatsApp payment poll; can also be toggled from
  /// the admin match page. Scheduler uses this to chase unpaid players
  /// on the daily 17:00 squad nudge. Nullable = additive, zero impact
  /// on historical attendance rows.
  paidAt      DateTime?
  /// When this attendance was paid for via someone else (bulk
  /// payment by the same WhatsApp member who collected several
  /// players' fees). Populated when an admin says e.g. "Amir paid
  /// for Faris and Adam" — the bot resolves Amir → User and stores
  /// his id here against Faris's and Adam's Attendance rows. Useful
  /// for audit / undo. Nullable = additive.
  paidViaUserId String?

  /// ─── Stripe per-player payment (2026-06-03) ─────────────────────
  /// How this player chose to pay: "pay_by_bank" | "card" | "direct".
  /// Null until they pick / are sent a link.
  paymentMethod      String?
  /// Total charged for this row incl. the per-method processing uplift
  /// (and quantity if they paid for others). £.
  paymentAmount      Float?
  /// How many people this payment covered (self + guests). Default 1.
  paymentQuantity    Int       @default(1)
  /// Stripe Checkout Session id (card / pay-by-bank). Null for direct.
  stripeSessionId    String?
  /// Set when the player chose "pay the collector directly" and we're
  /// awaiting the collector's confirmation. Cleared (→ paidAt) on confirm.
  directPendingAt    DateTime?
  /// Who confirmed the direct payment (the money collector).
  directConfirmedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId])
  @@index([matchId, status])
}

/**
 * Bulk-payment credit recorded by an admin via natural-language WA
 * message (e.g. "Amir paid for 4 players"). Used when individual
 * names aren't given and we just have a count to credit against the
 * match. Each row offsets the unpaid count for that match by `count`.
 *
 * If the admin DOES name specific players, the bot updates each
 * Attendance.paidAt + paidViaUserId directly and does NOT create a
 * PaymentCredit row — avoids double-counting.
 *
 * Authorisation: only OWNER/ADMIN of the org can create these.
 */
model PaymentCredit {
  id            String   @id @default(cuid())
  matchId       String
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  payerUserId   String                                           // who collected/paid the venue
  count         Int                                              // how many players' fees this covers
  note          String?                                          // optional context
  recordedById  String                                           // sender of the credit instruction (for audit)
  recordedAt    DateTime @default(now())

  @@index([matchId])
}

model TeamAssignment {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  team    Team

  @@unique([matchId, userId])
}

model Rating {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  raterId  String
  rater    User   @relation("RatingsGiven", fields: [raterId], references: [id])
  playerId String
  player   User   @relation("RatingsReceived", fields: [playerId], references: [id])
  score    Int    // 1-10

  createdAt DateTime @default(now())

  @@unique([matchId, raterId, playerId])
}

model MoMVote {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  voterId  String
  voter    User   @relation("MoMVotesGiven", fields: [voterId], references: [id])
  playerId String
  player   User   @relation("MoMVotesReceived", fields: [playerId], references: [id])

  createdAt DateTime @default(now())

  @@unique([matchId, voterId])
}

/**
 * Smart-analysis dedupe key: every WhatsApp group message the bot
 * processes gets recorded here by its `waMessageId`. The inline path
 * (fast-path + LLM), periodic catch-up scan, and startup backfill all
 * check this table first so no message is processed twice. The
 * `intent` / `action` columns record what the bot decided, useful for
 * auditing and prompt-tuning.
 *
 * handledBy:
 *   - "fast-path": regex matched (IN/OUT/score); acted inline
 *   - "llm":       sent to Claude for classification; action executed
 *   - "ignored":   skipped on purpose (bot's own msg, non-c.us author, empty body)
 *   - "error":     analyzer call failed; don't re-try this exact message
 */
model AnalyzedMessage {
  id           String   @id @default(cuid())
  waMessageId  String   @unique
  orgId        String
  groupId      String
  authorPhone  String?
  authorUserId String?
  /// WhatsApp pushname at analysis time. Persisted so the admin
  /// "unresolved messages" queue can show WHO ("ba") to link to a
  /// player when authorUserId is null. Nullable + additive.
  authorName   String?
  body         String?  @db.Text
  handledBy    String
  intent       String?
  action       String?
  confidence   Float?
  reasoning    String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([groupId, createdAt])
  @@index([orgId, authorUserId, createdAt])
}

/**
 * Per-org alias for a user — the WhatsApp pushname (or nickname /
 * variant spelling) that doesn't fuzzy-match the canonical DB name.
 *
 * Populated automatically when an admin merges a provisional ghost
 * into a real user: the ghost's display name becomes an alias for
 * the real user, scoped to the org. Next time a message arrives with
 * that pushname (and no phone — typical @lid privacy mode case), the
 * resolver finds the real user via alias instead of creating another
 * ghost.
 *
 * Stored lower-cased + diacritics-stripped to match the resolver's
 * comparison key.
 */
model UserAlias {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     String
  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  alias     String                            // already-normalised key
  source    String       @default("merge")    // "merge" | "manual" | "auto-detect"
  createdAt DateTime     @default(now())

  @@unique([orgId, alias])
  @@index([userId])
  @@index([orgId])
}

/**
 * Merge tombstone (2026-06-12). When two duplicate User rows are merged,
 * the dropped row is DELETED — so any id captured before the merge (e.g.
 * a rated playerId baked into a rating submission, a cached squad list)
 * becomes a dangling reference. This row records old→new so those stale
 * ids can be REMAPPED to the survivor instead of silently dropped.
 *
 * `oldUserId` is a PLAIN STRING, not an FK — the row it points at is
 * gone by the time this is queried. Chains are possible (a survivor may
 * itself later be merged away), so readers follow `oldUserId →
 * survivorUserId` transitively with a small hop cap to break cycles.
 *
 * Written inside the same transaction as the user delete in
 * `mergePlayersCore`. Read by `submitRatings` / `submitMoMVote` to
 * remap a merged-away player to the survivor (respecting their unique
 * keys) rather than skipping the score.
 */
model UserMerge {
  id             String   @id @default(cuid())
  oldUserId      String                          // dropped (deleted) user id — NOT an FK
  survivorUserId String                          // surviving keeper user id
  orgId          String
  createdAt      DateTime @default(now())

  @@index([oldUserId])
}

/**
 * Phase 4 hybrid LLM team-balancer audit trail.
 *
 * Before the deterministic balancer runs, an LLM reads the last ~7 days
 * of group chat and proposes per-player rating deltas based on
 * conditions for tonight (sick, tentative, hot streak, rusty). The
 * balancer then runs with the adjusted ratings.
 *
 * One row per (match, user) — captures what the LLM said and why so an
 * admin can audit balance decisions ("why was Wasim on Yellow?").
 *
 * Delta is clamped to [-2, +2] in the analyser so a single hallucination
 * can't dominate the balance. Confidence < 0.3 is treated as no signal.
 */
model RatingAdjustment {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  delta      Float
  reason     String   @db.Text
  confidence Float
  createdAt  DateTime @default(now())

  @@unique([matchId, userId])
  @@index([matchId])
}

/**
 * Raw archive of group messages for orgs running `featureSquadFromList`.
 *
 * For those orgs (Amir's Thursday group, 2026-05-20) the per-batch
 * analyzer is OFF (cost) but we still need to read the latest pasted
 * squad list to know who played, so the bot DMs the right people for
 * MoM voting + ratings. The analyze route stores every inbound message
 * here without calling the LLM. A single squad-extraction LLM call
 * (Sonnet, folded into /api/cron/generate-teams — Vercel project cron
 * cap = 3) runs over messages SINCE THE PREVIOUS MATCH ENDED to find
 * squad lists, attribute additions to senders (ground-truth UserAlias
 * learning), and resolve the final squad at kickoff. Starting at the
 * previous match's end (not a fixed rolling window) matters because
 * some groups paste the next week's list within minutes of the final
 * whistle — a rolling window would either chop those off or drag in
 * stale lists from before the previous match.
 *
 * Only written when the org has `featureSquadFromList=true` — Sutton
 * and other live orgs are unaffected.
 *
 * Idempotent on `waMessageId` (unique). Sender resolution happens at
 * extraction time, not write time, so a phone + pushname pair becomes
 * useful even before the User exists in our DB.
 */
model GroupMessage {
  id             String   @id @default(cuid())
  orgId          String
  org            Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  waMessageId    String   @unique
  waChatId       String?
  /// E.164 phone of the sender, if WhatsApp delivered one. Empty/null
  /// when the sender is @lid (privacy mode) — pushname is then the
  /// only handle we have.
  senderPhone    String?
  /// WhatsApp pushname (display name) at message time. Persisted so the
  /// diff-attribution pass can compare "what name did this sender add"
  /// against "what name does this sender go by", to learn aliases.
  senderPushname String?
  body           String   @db.Text
  /// WhatsApp's own message timestamp (UTC). The diff pass orders by
  /// this — NOT createdAt — so out-of-order ingestion (Pi catch-up
  /// after a restart) still produces the correct list sequence.
  timestamp      DateTime
  createdAt      DateTime @default(now())

  @@index([orgId, timestamp])
}

/**
 * Shadow analyzer output (2026-05-29). The current `/api/whatsapp/analyze`
 * route forces Claude to emit a structured verdict per message, then
 * runs server-side regex safety-nets to "fix" wrong verdicts. That
 * bandaid layer is itself the source of recurring bugs (Kemal dropped
 * from his own squad 2026-05-28; Mojib not dropped 2026-05-26; etc.).
 *
 * The shadow path runs alongside the live analyzer on every Pi flush.
 * It sends the SAME window (fresh batch + history) to a fresh, concise
 * prompt that returns ONE coherent state diff for the window — no
 * per-message verdicts to conflict with each other, no safety nets to
 * override. Output is persisted here for offline comparison; no
 * attendance is written by this path until we cut over.
 *
 * `currentVerdictRefs` is the array of AnalyzedMessage IDs that the
 * LIVE analyzer wrote for the same batch, so the /admin/shadow dash
 * can render side-by-side: shadow's single diff vs live's per-message
 * verdicts, with a cheap "agree?" badge.
 */
model WindowVerdict {
  id                  String   @id @default(cuid())
  orgId               String
  org                 Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// First message timestamp in the batch (or now() if the batch was empty).
  windowStart         DateTime
  /// Last message timestamp in the batch.
  windowEnd           DateTime
  /// SHA-256 of the sorted waMessageIds in the batch — lets us dedupe
  /// re-runs on the same window (Pi catch-up resending) without a
  /// second Claude call.
  batchHash           String
  /// Wall-clock ms the shadow Claude call took. Cheap proxy for window
  /// complexity + lets us spot regressions.
  modelMs             Int
  /// Best-effort USD cost of this shadow call (input+output tokens).
  /// Null if pricing lookup failed.
  costUsd             Float?
  /// Full Claude response parsed into our shadow schema. See
  /// `src/lib/window-analyzer.ts` for the type. Includes
  /// stateChanges, reactions, optional groupReply, windowSummary.
  verdictJson         Json
  /// The AnalyzedMessage IDs that the live per-message analyzer wrote
  /// for this same batch. Used by the dashboard for side-by-side.
  currentVerdictRefs  String[]
  createdAt           DateTime @default(now())

  @@unique([orgId, batchHash])
  @@index([orgId, windowEnd])
}

/// Short-code wrapper for magic links (2026-06-05). The DM contains
/// `/r/<code>` (~30 chars) instead of the full ~250-char signed token;
/// the code resolves back to the token server-side via /api/r/[code].
/// Purely additive — legacy long-token links (which contain a ".") bypass
/// this entirely and keep working. Generation falls back to the long URL
/// if a row can't be written, so a DB hiccup never breaks sign-in links.
model ShortLink {
  /// Random URL-safe code, e.g. "k7Qp2m9".
  code      String   @id
  /// The full signed magic-link token this code stands in for.
  token     String   @db.Text
  /// Mirrors the token's own exp — the resolver rejects expired codes.
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
